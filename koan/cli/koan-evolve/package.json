{
  "name": "@zen/koan-evolve",
  "version": "1.0.0",
  "description": "CLI tool for evolutionary prompt system with fitness tracking and variant selection",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "koan-evolve": "./bin/koan-evolve"
  },
  "scripts": {
    "build": "tsc",
