{
  "name": "@zen/koan-bridge",
  "version": "1.0.0",
  "description": "Cross-project memory bridge — share learnings between projects",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "koan-bridge": "./bin/koan-bridge"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@zen/koan-core": "file:../koan-core",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  }
}
