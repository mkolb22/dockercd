{
  "name": "@zen/koan-migrate",
  "version": "1.0.0",
  "description": "Migrate koan/ YAML state files to SQLite state.db",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "koan-migrate": "./bin/koan-migrate"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@zen/koan-core": "file:../koan-core",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "better-sqlite3": "^11.0.0",
    "fast-glob": "^3.3.3",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  }
}
