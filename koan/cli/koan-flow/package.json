{
  "name": "@zen/koan-flow",
  "version": "1.0.0",
  "description": "Live workflow execution engine — generates executable plans from pipeline DSL",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "koan-flow": "./bin/koan-flow"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@zen/koan-core": "file:../koan-core",
    "@zen/koan-compose": "file:../koan-compose",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  }
}
