{
  "name": "@zen/koan-validate",
  "version": "1.0.0",
  "description": "CLI tool to validate koan/ YAML files against JSON schemas",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "koan-validate": "./bin/koan-validate"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@zen/koan-core": "file:../koan-core",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "fast-glob": "^3.3.3",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  }
}
